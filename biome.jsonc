{
  "extends": [
    "@fandhe-ai/shared-config-biome/core",
    "@fandhe-ai/shared-config-biome/root",
    "@fandhe-ai/shared-config-biome/import"
  ],
  "files": {
    "includes": [
      "apps/**",
      "packages/**",
      "!**/node_modules",
      "!**/build",
      "!**/dist",
      "!**/.next",
      "!**/.react-router",
      "!**/.turbo",
      "!**/public",
      "!**/*.css",
      "!**/playwright-report",
      "!**/test-results",
      "!**/coverage",
      "!**/storybook-static",
      "!**/blob-inputs",
      "!**/reports",
      "!.agents",
      "!.claude/skills",
      "!.claude/worktrees"
    ]
  }
}
